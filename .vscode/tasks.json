{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run problem",
            "type": "shell",
            "command": "PKG=$(basename $(dirname $(dirname '${file}'))); cargo run -p \"$PKG\" < \"problems/$PKG/input.txt\"",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$rustc"
        }
    ]
}
